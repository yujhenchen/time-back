{
  "name": "time-guard",
  "displayName": "Time guard",
  "version": "0.0.1",
  "description": "save your time",
  "license": "MIT",
  "author": "Jen C.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "build:firefox-mv2": "plasmo build --target=firefox-mv2",
    "build:firefox-mv3": "plasmo build --target=firefox-mv3",
    "package": "plasmo package",
    "debug": "plasmo dev --verbose",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@plasmohq/storage": "^1.15.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.71.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "0.0.258",
    "@types/jest": "^30.0.0",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.24",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.11",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "declarativeNetRequest",
      "sidePanel",
      "storage",
      "webRequest",
      "webRequestBlocking"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "blocked.html"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "{ed7ba470-8e54-465e-825c-99712043e01c}",
        "strict_min_version": "91.0"
      }
    }
  }
}